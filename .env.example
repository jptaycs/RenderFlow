# Copy to .env and fill in. Never commit .env.
ANTHROPIC_API_KEY=
REPLICATE_API_TOKEN=
ELEVENLABS_API_KEY=

# Provider selection (config change, not code change)
# Free stack: pollinations (images, no key) + piper (local TTS, no key).
# Paid stack: flux-replicate + elevenlabs (fill in keys above).
RENDERFLOW_LLM_PROVIDER=claude
# pollinations: free AI generation (no key) · flux-replicate: paid AI
# pexels: free stock-photo search instead of generation (needs
#   PEXELS_API_KEY below; set RENDERFLOW_AVATAR_IMAGE too — stock search
#   can't produce a consistent host portrait from a description).
RENDERFLOW_IMAGE_PROVIDER=pollinations
# Thumbnail images can use different providers than scene images (empty =
# same as RENDERFLOW_IMAGE_PROVIDER). E.g. with pexels scenes, keep the
# clickbait background AI-generated (stock search rarely has the dramatic
# saturated look) while the reaction face is a real stock photo:
#   RENDERFLOW_THUMBNAIL_BG_PROVIDER=pollinations
RENDERFLOW_THUMBNAIL_BG_PROVIDER=
RENDERFLOW_THUMBNAIL_REACTION_PROVIDER=
# piper: fast/robotic · kokoro: natural prosody, local, Apache-2.0
#   (pip install '.[kokoro]' && python scripts/setup_kokoro.py, ~340 MB)
RENDERFLOW_TTS_PROVIDER=kokoro
# ffmpeg-still: free local placeholder (static image, no lip sync).
# wav2lip-local: free unlimited local lip sync + camera push-in (setup:
#   pip install '.[wav2lip]' && python scripts/setup_wav2lip.py, ~520 MB).
# sadtalker-replicate: paid lip sync + real head motion via Replicate
#   (needs REPLICATE_API_TOKEN; ~$0.08-0.15 per short clip).
# memo-hf: free HF Space, demo-only (4s audio cap, needs HF_TOKEN below).
RENDERFLOW_AVATAR_PROVIDER=ffmpeg-still
# Optional, for memo-hf: free token from huggingface.co/settings/tokens.
HF_TOKEN=
# Optional, for pollinations: free token from auth.pollinations.ai.
# Without it images are silently capped at 1024x576 (soft when upscaled).
POLLINATIONS_TOKEN=
# For image provider "pexels": free key from pexels.com/api
# (200 requests/hour, 20k/month; commercial use OK, no attribution needed).
PEXELS_API_KEY=

# Provider tuning
RENDERFLOW_LLM_MODEL=claude-opus-4-8
# kokoro: am_onyx (deep US male), bm_george (older British), am_fenrir.
# piper: voice name (download: python -m piper.download_voices <name> --data-dir .voices)
# elevenlabs: use a premade voice ID (library voices are blocked on the
# free tier), e.g. George the storyteller: JBFqnCBsd6RMkjVDRZzb
RENDERFLOW_TTS_VOICE=am_onyx
# Piper only: higher is slower, lower is faster. 1.4 reads like documentary
# narration; 1.25 is brisker.
RENDERFLOW_TTS_LENGTH_SCALE=1.4
# Piper only: silence between sentences (seconds). Real narration breathes;
# 0.45 is a natural documentary pause, 0 disables.
RENDERFLOW_TTS_SENTENCE_PAUSE=0.45
# Scene motion: parallax (depth-aware 2.5D camera moves, needs
# pip install '.[parallax]'; falls back to zoompan automatically) or zoompan.
RENDERFLOW_MOTION=parallax

# --- Output polish ---
# Stock-video B-roll: full-frame scenes use a real stock clip instead of a
# still+motion when one is found (falls back to the still). "pexels-video"
# uses the same free PEXELS_API_KEY; empty disables.
RENDERFLOW_BROLL_PROVIDER=
# Background music: drop royalty-free tracks into this dir (see
# music/README.md); each project picks one, looped + auto-ducked under the
# narration. Volume is the pre-duck level.
#RENDERFLOW_MUSIC_DIR=music
#RENDERFLOW_MUSIC_VOLUME=0.20
# Scene transitions: "fade" (video-only dip-through-black in the scene
# pause) or "none". Audio is never crossfaded.
#RENDERFLOW_TRANSITION=fade
# Intro title card + subscribe outro card (1 = on). Channel name appears on
# both cards when set.
#RENDERFLOW_INTRO_OUTRO=1
#RENDERFLOW_CHANNEL_NAME=
# Optional local image used as the presenter portrait for talking-avatar scenes.
RENDERFLOW_AVATAR_IMAGE=eliasyoder.jpg
RENDERFLOW_PROJECTS_DIR=projects

# SaaS layer (dashboard API + Celery worker; the CLI pipeline ignores these).
# Datastores come from docker-compose.yml — defaults below match it.
# RENDERFLOW_ENV=production makes cookies Secure and refuses to start with
# any dev flag set or the default DB password (see deploy/README.md; the
# production template is deploy/env.production.example). Dev leaves it unset.
#RENDERFLOW_ENV=dev
# Postgres password, interpolated by docker-compose.yml; dev default is
# fine on localhost, production generates one (setup_server.sh).
#RENDERFLOW_PG_PASSWORD=
RENDERFLOW_DATABASE_URL=postgresql+psycopg://renderflow:renderflow@127.0.0.1:5433/renderflow
RENDERFLOW_REDIS_URL=redis://127.0.0.1:6380/0
# Signs login session cookies — the API refuses to start without it.
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
RENDERFLOW_SECRET_KEY=
# Optional, LOCAL DEV ONLY: when both are set, the login page shows a
# one-click "Developer login" button that prefills these credentials and
# submits them through the normal password-checked login (no bypass
# endpoint exists). Leave unset on any deployed instance.
RENDERFLOW_DEV_LOGIN_EMAIL=
RENDERFLOW_DEV_LOGIN_PASSWORD=
# Optional, LOCAL DEV ONLY: makes POST /api/billing/checkout activate a
# subscription plan instantly with no payment (the seam where Stripe/Paddle
# plugs in later). Leave unset on a deployed instance — checkout then
# returns 503 "payments not configured".
RENDERFLOW_DEV_CHECKOUT=
