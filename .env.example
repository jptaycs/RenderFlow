# Copy to .env and fill in. Never commit .env.
ANTHROPIC_API_KEY=
REPLICATE_API_TOKEN=
ELEVENLABS_API_KEY=

# Provider selection (config change, not code change)
# Free stack: pollinations (images, no key) + piper (local TTS, no key).
# Paid stack: flux-replicate + elevenlabs (fill in keys above).
RENDERFLOW_LLM_PROVIDER=claude
RENDERFLOW_IMAGE_PROVIDER=pollinations
RENDERFLOW_TTS_PROVIDER=piper
# ffmpeg-still: free local placeholder (static image, no lip sync).
# wav2lip-local: free unlimited local lip sync + camera push-in (setup:
#   pip install '.[wav2lip]' && python scripts/setup_wav2lip.py, ~520 MB).
# sadtalker-replicate: paid lip sync + real head motion via Replicate
#   (needs REPLICATE_API_TOKEN; ~$0.08-0.15 per short clip).
# memo-hf: free HF Space, demo-only (4s audio cap, needs HF_TOKEN below).
RENDERFLOW_AVATAR_PROVIDER=ffmpeg-still
# Optional, for memo-hf: free token from huggingface.co/settings/tokens.
HF_TOKEN=

# Provider tuning
RENDERFLOW_LLM_MODEL=claude-opus-4-8
# piper voice name (download: python -m piper.download_voices <name> --data-dir .voices)
# For elevenlabs use a premade voice ID (library voices are blocked on the
# free tier), e.g. George the storyteller: JBFqnCBsd6RMkjVDRZzb
RENDERFLOW_TTS_VOICE=en_US-lessac-medium
# Piper only: higher is slower, lower is faster. 1.4 reads like documentary
# narration; 1.25 is brisker.
RENDERFLOW_TTS_LENGTH_SCALE=1.4
# Piper only: silence between sentences (seconds). Real narration breathes;
# 0.45 is a natural documentary pause, 0 disables.
RENDERFLOW_TTS_SENTENCE_PAUSE=0.45
# Optional local image used as the presenter portrait for talking-avatar scenes.
RENDERFLOW_AVATAR_IMAGE=eliasyoder.jpg
RENDERFLOW_PROJECTS_DIR=projects
