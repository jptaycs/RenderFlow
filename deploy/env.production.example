# Production .env template — deploy/setup_server.sh copies this to
# /opt/renderflow/.env (only if none exists) and fills in the generated
# values marked __GENERATED__. Fill in your provider keys after setup.

RENDERFLOW_ENV=production

# --- Datastores (docker-compose.yml reads RENDERFLOW_PG_PASSWORD too) ---
RENDERFLOW_PG_PASSWORD=__PG_PASSWORD__
RENDERFLOW_DATABASE_URL=postgresql+psycopg://renderflow:__PG_PASSWORD__@127.0.0.1:5433/renderflow
RENDERFLOW_REDIS_URL=redis://127.0.0.1:6380/0
RENDERFLOW_SECRET_KEY=__SECRET_KEY__

# --- Providers: the free stack (works with no paid keys) ---
RENDERFLOW_LLM_PROVIDER=claude
RENDERFLOW_IMAGE_PROVIDER=pollinations
RENDERFLOW_THUMBNAIL_BG_PROVIDER=
RENDERFLOW_THUMBNAIL_REACTION_PROVIDER=
RENDERFLOW_TTS_PROVIDER=kokoro
RENDERFLOW_AVATAR_PROVIDER=wav2lip-local
RENDERFLOW_MOTION=parallax

# --- Provider keys (fill in what you use) ---
ANTHROPIC_API_KEY=
REPLICATE_API_TOKEN=
ELEVENLABS_API_KEY=
PEXELS_API_KEY=
POLLINATIONS_TOKEN=
HF_TOKEN=

# --- Tuning ---
RENDERFLOW_LLM_MODEL=claude-opus-4-8
RENDERFLOW_TTS_VOICE=am_onyx
RENDERFLOW_TTS_LENGTH_SCALE=1.4
RENDERFLOW_TTS_SENTENCE_PAUSE=0.45
# Presenter portrait for talking-avatar scenes (path on the server).
RENDERFLOW_AVATAR_IMAGE=eliasyoder.jpg
RENDERFLOW_PROJECTS_DIR=projects

# Dev flags MUST stay unset in production — the API refuses to start
# otherwise (they bypass auth / activate subscriptions without payment).
# RENDERFLOW_DEV_LOGIN_EMAIL=
# RENDERFLOW_DEV_LOGIN_PASSWORD=
# RENDERFLOW_DEV_CHECKOUT=
